L1_MODE=local

# Local L1 mode runs the prover under Rosetta on Apple Silicon, so serve dummy
# proofs by default. Set to false only for real partial-mode proof validation.
PROVER_DEV_OVERRIDE=true

# Optional local L1 host port overrides.
# HOST_PORT_L1_RPC=8445
# HOST_PORT_L1_WS=8446
# HOST_PORT_L1_ENGINE=8551
# HOST_PORT_L1_CL_REST=4003
